# ============================================================================
# Database (PostgreSQL)
# ============================================================================
# When running via `docker compose up`, the host is `db`. When running the
# Next.js dev server outside docker against the compose-managed database,
# replace `db` with `localhost`.
DATABASE_URL="postgresql://gravity:gravity@db:5432/gravity_telemetry"

# Used by docker-compose to provision the postgres container.
POSTGRES_PASSWORD="gravity"

# ============================================================================
# Sessions
# ============================================================================
# Random 32+ byte string. Generate with: openssl rand -hex 32
# Cookies remain valid across restarts as long as this stays stable.
SESSION_SECRET="change-me-to-a-long-random-string"

# ============================================================================
# Admin bootstrap
# ============================================================================
# On first seed, an admin user is created with these credentials and
# `mustChangePassword=true`. Change the password on first login.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"

# ============================================================================
# Public base URL (used in metadata / share links)
# ============================================================================
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
