# Database (PostgreSQL)
DATABASE_URL="postgresql://gravity:gravity@localhost:5432/gravity"

# Public base URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Admin auto-seed (creates user with mustChangePassword=true on first startup)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-immediately"

# Public registration: when "true", anyone can create an account at /register.
# When "false" (default), only admins can create users via /admin/users.
# Set both vars to the same value — server route checks ALLOW_PUBLIC_REGISTRATION,
# client UI checks NEXT_PUBLIC_ALLOW_PUBLIC_REGISTRATION.
ALLOW_PUBLIC_REGISTRATION="false"
NEXT_PUBLIC_ALLOW_PUBLIC_REGISTRATION="false"

# Run ship seed script via docker entrypoint (one-time bootstrap)
RUN_SEED="true"

# Postgres docker compose secrets (used by docker-compose.yml)
POSTGRES_PASSWORD="gravity"
